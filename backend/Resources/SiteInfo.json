     "maxpreps_games":{
    "site_url": "https://www.maxpreps.com",
      "scraping": {
        "steps": [
          {
            "description": "State-level directory of teams",
            "scrape_method":["entry","access_each"],
            "pattern": "/{state}/{sport}/schools/"
          },
          {
            "description": "Main landing page for a specific team",
            "scrape_method": ["match","extract","fork","access_each"],
            "append": {
              "string": "/schedule/"
            },
            "fork":{
              "replace":true,
              "current_pattern":"/{state}/{county}/{team_name}/{sport}",
              "requested_patterns":["/{state}/{county}/{team_name}/{sport}/24-25/schedule",
              "/{state}/{county}/{team_name}/{sport}/23-24/schedule",
              "/{state}/{county}/{team_name}/{sport}/22-23/schedule"]
            },
            "match": {
              "pattern": "/{state}/{county}/{team_name}/{sport}",
              "tag": "a",
              "attr": "href"
            },
            "extract": {
              "type": "href"
            }
          },
          {
            "description": "All games of school",
            "scrape_method": ["match","store","extract","access_each"],
            "match": {
              "regex_pattern": "https",
              "pattern": "/games/{date}/{sport_year}/{game_id}",
              "tag": "a",
              "attr": "href"
            },
            "extract": {
              "type": "href"
            },
            "store": {
              "path": "BoxScoresContext/",
              "method": "all",
              "ext": ".txt",
              "name_scheme":"number"
            }
          },
          {
            "description": "Individual athlete profile page",
            "scrape_method": ["match","store"],
            "match": {
              "must_store": "NONEFOUND",
              "pattern": "ContestStatsContentPanel",
              "tag": "div",
              "attr": "id"
            },
            "store": {
              "path": "BoxScoresDOM/",
              "method": "all",
              "ext": ".txt",
              "name_scheme":"number"
            }
          }
        ]
      }
  },
